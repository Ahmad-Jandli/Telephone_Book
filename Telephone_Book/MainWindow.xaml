<Window x:Class="Telephone_Book.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Telephone_Book"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="800"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Background>
        <ImageBrush ImageSource="/phone book 3.jpg" Opacity="1"/>
    </Window.Background>

    <Border CornerRadius="25">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Margin="20,10,20,5"
                    CornerRadius="15"
                    Padding="10">

                <Grid>

                    <Button Content="X"
                            Width="30"
                            Height="30"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,5,5,0"
                            Style="{StaticResource RoundedButtonStyle}"
                            Click="BtnClose_Click" Foreground="#FF91AAFF">
                        <Button.BorderBrush>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="Black"/>
                                <GradientStop Color="#FF91AAFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.BorderBrush>
                    </Button>


                    <TextBlock Text="Phone Book System"
                               FontSize="24"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,30,0,0"
                               FontFamily="Sitka Banner Semibold"
                               FontStyle="Italic">

                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Black"/>
                                <GradientStop Color="#FF91AAFF" Offset="0.5"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>

                    </TextBlock>

                </Grid>

            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="150"/>

                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>


                <StackPanel Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,10,10,10" Width="160">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="120" VerticalAlignment="Center" Margin="10,5,10,5">
                        <Button Content="Add" Width="50" Margin="5" Style="{StaticResource RoundedButtonStyle}"/>
                        <Button Content="Edit" Width="50" Margin="5" Style="{StaticResource RoundedButtonStyle}"/>
                    </StackPanel>


                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="120" VerticalAlignment="Center" Margin="5,5,5,5">
                        <Button Content="Delete" Width="50" Margin="5" Style="{StaticResource RoundedButtonStyle}"/>
                        <Button Content="Search" Width="50" Margin="5" Style="{StaticResource RoundedButtonStyle}"/>
                    </StackPanel>


                    <Button Content="Print" Width="50" Margin="5,10,5,10" HorizontalAlignment="Center" Style="{StaticResource RoundedButtonStyle}"/>

                </StackPanel>


                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,10,0,10">
                    <TextBlock Text="Name" HorizontalAlignment="Center" Margin="5">
                        <TextBlock.Foreground>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="Black"/>
                                <GradientStop Color="#FF91AAFF" Offset="0.396"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBox Name="txtName" Width="140" Margin="5" HorizontalAlignment="Center" Background="{x:Null}">
                        <TextBox.Foreground>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="Black"/>
                                <GradientStop Color="#FF91AAFF" Offset="0.392"/>
                            </LinearGradientBrush>
                        </TextBox.Foreground>
                        <TextBox.BorderBrush>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="Black"/>
                                <GradientStop Color="#FF91AAFF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBox.BorderBrush>
                    </TextBox>
                    <TextBlock Text="Phone" HorizontalAlignment="Center" Margin="5">
                        <TextBlock.Foreground>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="Black"/>
                                <GradientStop Color="#FF91AAFF" Offset="0.365"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBox Name="txtPhone" Width="140" Margin="5" HorizontalAlignment="Center" Background="{x:Null}">
                        <TextBox.Foreground>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="Black"/>
                                <GradientStop Color="#FF91AAFF" Offset="0.358"/>
                            </LinearGradientBrush>
                        </TextBox.Foreground>
                        <TextBox.BorderBrush>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="Black"/>
                                <GradientStop Color="#FF91AAFF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBox.BorderBrush>
                    </TextBox>
                </StackPanel>
            </Grid>
            <Border Grid.Row="2"
        Margin="10"
        CornerRadius="15"
        BorderThickness="1"
        ClipToBounds="True">


                <DataGrid x:Name="myDataGrid"
          IsReadOnly="True"
          CanUserAddRows="False"
          AutoGenerateColumns="False"
          FontWeight="Bold"
          FontFamily="Sitka Banner Semibold"
          FontSize="14"
          BorderThickness="0"
          Background="{x:Null}"
          Grid.Row="2">
                    <DataGrid.Foreground>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="Black"/>
                            <GradientStop Color="#FF91AAFF" Offset="0.27"/>
                            <GradientStop Color="#FF91AAFF" Offset="0.27"/>
                        </LinearGradientBrush>
                    </DataGrid.Foreground>
                    <DataGrid.BorderBrush>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="Black"/>
                            <GradientStop Color="#FF91AAFF" Offset="1"/>
                        </LinearGradientBrush>
                    </DataGrid.BorderBrush>


                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                            <Setter Property="Foreground">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#99000000" Offset="0"/>

                                        <GradientStop Color="#FF91AAFF" Offset="1"/>

                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridColumnHeader">
                                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" FontSize="22" FontFamily="Segoe UI Semibold"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="*" FontSize="22" FontFamily="Segoe UI Semibold"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Border>
</Window>
